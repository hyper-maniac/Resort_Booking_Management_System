<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{!-- <link rel="stylesheet" href="css/home.css"> --}}
    <link rel="stylesheet" href="css/book.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">
    <title>XYZ Hotels Booking</title>
</head>

<body>
    
    <section class="booking-form">
        <h2>Book Your Stay</h2>
        <form action="/book" method="post">
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" required maxlength="500" placeholder="Enter your name">
    
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" placeholder="Enter your email" required>
    
            
                <label for="phone">Phone Number:</label>
                <input type="tel" id="phone" name="phone" required placeholder="Enter your phone number">
            <div class="input-group">
                <label for="check-in">Check-in Date:</label>
                <input type="date" id="check-in" name="checkIn" required>
    
                <label for="check-out">Check-out Date:</label>
                <input type="date" id="check-out" name="checkOut" required>
            </div>
    
            <div class="input-group">
                <label for="rooms">Number of Rooms:</label>
                <input type="number" id="rooms" name="rooms" min="1" max="3" required>
    
                <label for="guests">Number of Guests:</label>
                <input type="number" id="guests" name="guests" min="1" required>
            </div>
            
                <div class="totalAmount"></div>

            <button type="submit" class="btn"><a href="confirmation.hbs">Pay Now</a></button>
        </form>
    </section>
    {{#if isSignedIn}}
  <form action="/signin" method="GET" style="display: inline;">
   
    <form action="/signin" method="GET" style="display: inline;">
  <button style="background-color: rgb(254, 183, 60); border-radius: 5px; padding: 7px; color:black " disabled>{{username}}</button>
</form>

  </form>
  <form action="/logout" method="GET" style="display: inline;">
    <button style="background-color: rgb(254, 183, 60); border-radius: 5px; padding: 7px;">
      <a href="logout" style="color: black; text-decoration: none;">Log out</a>
    </button>
  </form>
   {{else}}
    <!-- User is signed out -->
    <div style="display:flex;margin-left: 400px;margin-right: 400px;">
    <button style="background-color: rgb(254, 183, 60); border-radius: 5px; padding: 7px;">
      <a href="signin" style="color: black; text-decoration: none;">Sign Up</a>
    </button>
    <!-- Login button -->
    <button style="background-color: rgb(254, 183, 60); border-radius: 5px; padding: 7px;">
      <a href="login" style="color: black; text-decoration: none;">Login</a>
    </button>
    </div>
{{/if}}
    <br><br><br>
    
    <!-- Footer section -->
    <footer>
        <p>© 2024 XYZ Hotels. All rights reserved.</p>
    </footer>
    <script src="js/bookki.js"></script>
</body>
</html>
